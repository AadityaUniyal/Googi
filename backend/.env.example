# ===========================================================
# DocIntel AI Platform — Environment Variables
# ===========================================================
# Copy this file to `.env` and fill in the values.
# Lines starting with '#' are comments and are ignored.
# ===========================================================

# ---- Database (PostgreSQL / Neon) ----
# Format: postgresql://USER:PASSWORD@HOST:PORT/DBNAME?sslmode=require
DATABASE_URL=postgresql://neondb_owner:YOUR_PASSWORD@ep-XXXX.us-east-1.aws.neon.tech/neondb?sslmode=require

# ---- Security & Auth ----
# Generate a strong secret:  python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET_KEY=CHANGE_ME_GENERATE_A_SECURE_RANDOM_KEY

# ---- AI / Gemini (optional — required only for AI-powered field extraction) ----
GEMINI_API_KEY=

# ---- RabbitMQ Message Broker ----
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASS=guest

# ---- Redis Cache & Locking ----
REDIS_HOST=localhost
REDIS_PORT=6379

# ---- Application ----
# Set to false in production to disable debug mode
DEBUG=false

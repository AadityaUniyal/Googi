# ============================================================================
# DocIntel AI Platform - Frontend Dockerfile (Multi-Stage)
# ============================================================================
# Stage 1 (deps):    Install Node.js dependencies
# Stage 2 (builder): Build the Next.js application
# Stage 3 (runner):  Minimal runtime with standalone output
#
# Prerequisites:
#   Ensure next.config.js/ts has: output: 'standalone'
#
# Build:  docker build -t docintel-frontend ./frontend
# Run:    docker run -p 3000:3000 docintel-frontend
# ============================================================================

# --------------------------------------------------------------------------
# Stage 1: Install Dependencies
# --------------------------------------------------------------------------
FROM node:20-alpine AS deps

# Add libc6-compat for Alpine compatibility with some npm packages
RUN apk add --no-cache libc6-compat

WORKDIR /app

# Copy dependency manifests first for better layer caching
COPY package.json package-lock.json* yarn.lock* pnpm-lock.yaml* ./

# Install dependencies based on the available lock file
RUN \
    if [ -f package-lock.json ]; then npm ci --prefer-offline; \
    elif [ -f yarn.lock ]; then corepack enable && yarn install --frozen-lockfile; \
    elif [ -f pnpm-lock.yaml ]; then corepack enable pnpm && pnpm install --frozen-lockfile; \
    else echo "No lockfile found." && npm install; \
    fi

# --------------------------------------------------------------------------
# Stage 2: Build Application
# --------------------------------------------------------------------------
FROM node:20-alpine AS builder

WORKDIR /app

# Copy dependencies from deps stage
COPY --from=deps /app/node_modules ./node_modules

# Copy application source
COPY . .

# Disable Next.js telemetry during build
ENV NEXT_TELEMETRY_DISABLED=1

# Build the Next.js application
# Ensure next.config.js has output: 'standalone' for optimal Docker builds
RUN npm run build

# --------------------------------------------------------------------------
# Stage 3: Production Runtime
# --------------------------------------------------------------------------
FROM node:20-alpine AS runner

LABEL maintainer="Aaditya Uniyal" \
      org.opencontainers.image.title="DocIntel Frontend" \
      org.opencontainers.image.description="Next.js frontend for the DocIntel AI platform" \
      org.opencontainers.image.source="https://github.com/AadityaUniyal/Googi"

WORKDIR /app

# Set production environment
ENV NODE_ENV=production \
    NEXT_TELEMETRY_DISABLED=1 \
    PORT=3000 \
    HOSTNAME="0.0.0.0"

# Create non-root user for security
RUN addgroup --system --gid 1001 nodejs \
    && adduser --system --uid 1001 nextjs

# Copy the standalone build output from the builder stage
# The standalone output includes only the necessary server files
COPY --from=builder /app/public ./public

# Create .next directory owned by nextjs user
RUN mkdir .next && chown nextjs:nodejs .next

# Copy standalone server and static files
# These paths are generated by Next.js when output: 'standalone' is set
COPY --from=builder --chown=nextjs:nodejs /app/.next/standalone ./
COPY --from=builder --chown=nextjs:nodejs /app/.next/static ./.next/static

# Switch to non-root user
USER nextjs

# Expose the frontend port
EXPOSE 3000

# Health check
HEALTHCHECK --interval=30s --timeout=10s --start-period=15s --retries=3 \
    CMD wget --no-verbose --tries=1 --spider http://localhost:3000/ || exit 1

# Start the Next.js standalone server
CMD ["node", "server.js"]
